# DocIQ reads the REPO-ROOT .env (two levels up from backend/main.py).
# This file documents every var. Do NOT put real values here.

# Telegram
TELEGRAM_BOT_TOKEN=                  # @BotFather
CA_TELEGRAM_CHAT_ID=                 # CA's numeric Telegram user ID (@userinfobot)
TELEGRAM_MODE=polling                # "polling" (dev) | "webhook" (prod)
BACKEND_URL=                         # Required only if TELEGRAM_MODE=webhook (e.g. https://dociq.example.com)

# AI
OPENAI_API_KEY=                      # Primary (GPT-4o, GPT-4o-mini, embeddings)
OPENAI_API_KEY_SECONDARY=            # Fallback on RateLimitError
DEEPSEEK_API_KEY=                    # Client-facing replies (deepseek-chat)

# Supabase (already in repo .env as SUPABASE_SERVICE_KEY)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=                # Service role key — server-side only
